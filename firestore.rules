rules_version = '2';

// Reglas de seguridad - LOGYBOX Prueba Tecnica (ingreso por correo habilitado)
// Pega este contenido en: Firebase Console > Firestore Database > Reglas > Publicar

service cloud.firestore {
  match /databases/{database}/documents {

    // ¿El usuario autenticado esta registrado como admin?
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function candidato(id) {
      return get(/databases/$(database)/documents/candidates/$(id)).data;
    }

    // Lista de administradores (se crea manualmente desde la consola).
    match /admins/{uid} {
      allow get:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }

    // Prueba COMPLETA (con los puntos de cada opcion): solo el admin.
    match /config/test {
      allow read, write: if isAdmin();
    }

    // Prueba PUBLICA (sin puntos): cualquier usuario autenticado (incluye anonimo).
    match /config/testPublic {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Correos habilitados. El candidato (anonimo) puede LEER su propio correo
    // para verificar si esta habilitado, y marcar su nombre/estado al presentar.
    // NO puede listar la coleccion completa (eso solo el admin).
    match /candidates/{emailKey} {
      allow get:  if request.auth != null;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['name', 'status', 'submittedAt']));
    }

    // Respuestas enviadas. El candidato crea la suya UNA sola vez (create falla
    // si ya existe) y solo si su correo esta habilitado y no ha completado.
    match /submissions/{emailKey} {
      allow get:  if request.auth != null;
      allow list: if isAdmin();
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/candidates/$(emailKey))
        && candidato(emailKey).status != 'completed';
      allow update, delete: if isAdmin();
    }
  }
}
